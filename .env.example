# Get these from your Supabase project dashboard:
# Settings > API

VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Note: The Anthropic API for the Create Content module uses the
# built-in proxy (no API key needed in frontend code).
# The API calls go to api.anthropic.com/v1/messages directly.
# You may need to set up a Supabase Edge Function as a proxy
# if you want to keep your API key secure in production.
# See README for details.
